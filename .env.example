# --- 必填 ---
APP_SECRET_KEY=please-change-to-a-long-random-string
SHARED_LOGIN_PASSWORD=student123
ADMIN_LOGIN_PASSWORD=admin123
APP_ENV=development
COOKIE_SECURE=false

# --- OpenAI-compatible API（OpenRouter）---
OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1
OPENAI_COMPATIBLE_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_COMPATIBLE_MODEL=openai/gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
VISION_MODEL=openai/gpt-4o-mini
DEMO_MODE=false
PDF_VISION_STRATEGY=auto                  # auto / always / never；always 會讓每頁 PDF 都走 vision，成本較高
PDF_VISION_BATCH_SIZE=1
PDF_IMAGE_ZOOM=1.2
PDF_IMAGE_JPEG_QUALITY=70

# --- 上限 / Session ---
MAX_FILE_SIZE_MB=200
SESSION_EXPIRE_MINUTES=1440
RAG_TOKEN_THRESHOLD=12000
